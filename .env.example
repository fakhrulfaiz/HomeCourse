# ─────────────────────────────────────────────────────────────────────────────
# Video Learning Platform — environment variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default, recommended for self-hosting):
DATABASE_URL=file:/data/app.db
# PostgreSQL (legacy, if you still need it):
# DATABASE_URL=postgresql://vlearn:changeme@localhost:5432/vlearn

# ── Authentication ────────────────────────────────────────────────────────────
# Set to 'true' to disable login entirely — all users get full access.
# Useful for a trusted private network where you don't need accounts.
AUTH_DISABLED=false

# Auto-create an admin account on first boot (only used when AUTH_DISABLED=false).
# Leave blank to skip auto-creation; you can register manually via the UI instead.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme_strong_password

# JWT signing secret — change this to a long random string in production!
JWT_SECRET=changeme_jwt_secret_key_min_32_chars
JWT_EXPIRES_IN=7d

# ── Video Libraries ───────────────────────────────────────────────────────────
# Comma-separated list of directories the scanner will walk for courses.
# These must be the container-side paths (matching your volume mounts).
# Example with multiple libraries:
#   VIDEO_DIRS=/media/courses,/media/tutorials,/media/workshops
VIDEO_DIRS=/media/videos

# Host paths to mount into the container (used in docker-compose.prod.yml).
# Windows:  VIDEO_DIR_1=C:/Users/me/MyVideos
# Linux:    VIDEO_DIR_1=/home/me/videos
VIDEO_DIR_1=/path/to/your/videos
# VIDEO_DIR_2=/path/to/another/library

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
HTTP_PORT=8080

# ── Video Processing ──────────────────────────────────────────────────────────
ALLOWED_VIDEO_FORMATS=mp4,webm,mkv,avi,mov

# ── CORS ──────────────────────────────────────────────────────────────────────
# Set to your domain in production, e.g. https://videos.example.com
# Use * to allow all origins (fine for a local/private server)
CORS_ORIGIN=*

# ── GitHub Container Registry (GHCR) ─────────────────────────────────────────
# Your GitHub username — used in docker-compose.prod.yml image names.
# Images are published automatically via GitHub Actions (no extra secrets needed).
# Images will be at: ghcr.io/GITHUB_USERNAME/vlearn-backend:latest
GITHUB_USERNAME=yourgithubusername

# ── Frontend (development only) ───────────────────────────────────────────────
VITE_API_URL=http://localhost:3000/api
VITE_APP_NAME=Video Learning Platform
