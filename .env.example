# Database
DB_NAME=vlearn
DB_USER=vlearn
DB_PASSWORD=changeme_secure_password
DATABASE_URL=postgresql://vlearn:changeme_secure_password@localhost:5433/vlearn

# Redis
REDIS_PASSWORD=changeme_redis_password

# Video Library Path (relative to project root)
# This should point to your existing video directory
VIDEOS_BASE_PATH=../

# Backend
JWT_SECRET=changeme_jwt_secret_key_min_32_chars
JWT_EXPIRES_IN=7d
NODE_ENV=development
PORT=3000

# Video Processing
MAX_VIDEO_SIZE_MB=500
ALLOWED_VIDEO_FORMATS=mp4,webm,mkv,avi,mov
TRANSCODE_QUALITY=720p,480p,360p

# Frontend (add to frontend/.env.local)
VITE_API_URL=http://localhost:3000/api
VITE_APP_NAME=Video Learning Platform

# CORS
CORS_ORIGIN=http://localhost:5173
